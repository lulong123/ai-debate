# LLM Configuration
LLM_MODEL=openai/glm-5.1
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Multi-Model Routing: cp backend/config.example.yaml backend/config.yaml
# Uncomment models you want, put API keys here:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# MOONSHOT_API_KEY=
# QWEN_API_KEY=
# VOLCENGINE_API_KEY=

# Search (optional, leave empty to disable)
SEARCH_PROVIDER=
ZHIPU_SEARCH_API_KEY=
TAVILY_API_KEY=

# Discussion
MAX_ROUNDS=3
